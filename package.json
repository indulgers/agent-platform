{
  "name": "agent-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tool task agent — Vite/React frontend + NestJS backend",
  "author": "indulger",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "db:migrate": "pnpm --filter @agent-platform/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @agent-platform/api exec prisma migrate deploy",
    "db:studio": "pnpm --filter @agent-platform/api exec prisma studio",
    "db:generate": "pnpm --filter @agent-platform/api exec prisma generate"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
