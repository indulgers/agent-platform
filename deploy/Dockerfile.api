# Multi-stage build for the NestJS API. Builds the whole monorepo so workspace
# dependencies (@agent-platform/shared) resolve, then ships only the api app.

FROM node:20-slim AS base
RUN corepack enable && corepack prepare pnpm@9.11.0 --activate
WORKDIR /repo

# ---------- deps ----------
FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* turbo.json tsconfig.base.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN pnpm install --frozen-lockfile=false

# ---------- build ----------
FROM deps AS build
COPY packages ./packages
COPY apps/api ./apps/api
# Build the shared package FIRST — its package.json `main` points at dist/,
# so api's tsc can't resolve `@agent-platform/shared` until those files exist.
RUN pnpm --filter @agent-platform/shared build
RUN pnpm --filter @agent-platform/api exec prisma generate
RUN pnpm --filter @agent-platform/api build

# ---------- runtime ----------
FROM node:20-slim AS runtime
RUN corepack enable && corepack prepare pnpm@9.11.0 --activate \
 && apt-get update && apt-get install -y --no-install-recommends openssl ca-certificates \
 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ENV NODE_ENV=production

# Bring along everything pnpm symlinks — simplest reliable copy for a monorepo runtime.
COPY --from=build /repo/node_modules ./node_modules
COPY --from=build /repo/apps/api/node_modules ./apps/api/node_modules
COPY --from=build /repo/apps/api/dist ./apps/api/dist
COPY --from=build /repo/apps/api/prisma ./apps/api/prisma
COPY --from=build /repo/apps/api/package.json ./apps/api/
COPY --from=build /repo/packages/shared ./packages/shared
COPY --from=build /repo/package.json /repo/pnpm-workspace.yaml ./

EXPOSE 3000
WORKDIR /app/apps/api
CMD ["sh", "-c", "pnpm exec prisma migrate deploy && node dist/main.js"]
