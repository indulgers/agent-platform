# Database — dev compose maps host 5433 -> container 5432 (see deploy/docker-compose.dev.yml).
# In production the api talks to postgres over the internal docker network on 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agent_platform

# Redis (BullMQ + cache) — dev compose maps host 6380 -> container 6379.
REDIS_URL=redis://localhost:6380

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m

# LLM providers — fill in at least one
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com   # override if using a proxy or self-hosted gateway

# Pick the default provider. For DeepSeek, set LLM_DEFAULT_MODEL to one of:
#   deepseek-chat       — general-purpose (V3)
#   deepseek-reasoner   — R1 reasoning model
LLM_DEFAULT_PROVIDER=anthropic       # 'openai' | 'anthropic' | 'deepseek'
LLM_DEFAULT_MODEL=claude-sonnet-4-6
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Network
PORT=3000
WEB_ORIGIN=http://localhost:5173

# Agent loop limits
AGENT_MAX_ITERATIONS=8
AGENT_MAX_TOKENS=4096
