# Production env — copy to .env on the VPS, fill the marked values.
# This file ships in git; the real .env on the VPS does NOT.
#
#   ssh deploy@your-vps
#   cd ~/agent-platform
#   cp .env.production.example .env
#   nano .env
#
# Most secrets are required: docker compose will fail to start with a clear
# error if any of them are missing (we use the ${VAR:?msg} syntax in compose).

# ---- Postgres ----
# Pick a strong password. Survives container restarts via the pgdata volume.
POSTGRES_PASSWORD=CHANGEME_postgres_strong_password

# ---- Auth ----
# At least 32 random chars. e.g. `openssl rand -base64 48`
JWT_SECRET=CHANGEME_at_least_32_chars_of_random_secret
JWT_EXPIRES_IN=15m

# ---- LLM providers ----
# Set at least one. The default-provider env decides which one new conversations
# use when no per-conversation override is set in the UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com   # override if using a proxy

LLM_DEFAULT_PROVIDER=anthropic       # openai | anthropic | deepseek
LLM_DEFAULT_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# ---- Network ----
# Origin the web SPA serves from — used for CORS allowlist on the api.
# Set to the bare domain (with scheme) you'll hit in the browser.
WEB_ORIGIN=http://your-vps-ip-or-domain

# ---- S3 / MinIO ----
# Public endpoint = the URL the browser PUTs presigned-uploaded files to.
# Internal endpoint is fixed in compose to http://minio:9000 — no need to set.
# Set this to the same host you're serving the web app from, on port 9100.
S3_PUBLIC_ENDPOINT=http://your-vps-ip:9100
S3_REGION=us-east-1
# Pick strong credentials — MinIO's web console accepts these too.
S3_ACCESS_KEY=CHANGEME_minio_root_user
S3_SECRET_KEY=CHANGEME_minio_root_password_min_8_chars
S3_BUCKET=agent-platform

# ---- Agent loop ----
AGENT_MAX_ITERATIONS=8
AGENT_MAX_TOKENS=4096
